# Copy this file to .env.local and fill in your own Frigade keys.
# Grab free keys at https://frigade.com.

# Public (publishable) key. Used by the app in the browser. Required to run the demo.
NEXT_PUBLIC_FRIGADE_API_KEY=your_frigade_public_api_key

# Private key. Only needed to (re)create the demo's flows with
# scripts/provision-flows.mjs. Keep it out of version control.
FRIGADE_API_KEY_SECRET=your_frigade_private_api_key
